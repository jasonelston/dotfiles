#!/usr/bin/env bash
# Combined sesh + tmux-windows fuzzy picker.
# Tags each line so the dispatcher knows whether to use `sesh connect`
# or `sesh window`. Launched from a tmux display-popup; works standalone too.

set -euo pipefail
export PATH="$HOME/.fzf/bin:$HOME/.bin:/opt/homebrew/bin:$PATH"

picker() {
  # Windows first (=> bottom of fzf default layout, nearest cursor). Sort tiers
  # (printed first = closest to cursor, last = top of fzf):
  #   0. current attached session's active window — you are here
  #   1. other session's active window, by session_last_attached desc
  #      (= "switch to recent session"; lands you on its current window)
  #   2. current session's last window (prefix+L target)
  #   3. other session's last window, by session_last_attached desc
  #   4. current session's other windows, by window_index
  #   5. other session's other windows, by session_last_attached desc + index
  # Note: `window_active` is per-session — every session has exactly one.
  # `window_last_flag` is also per-session (each session has its own prefix+L
  # target). The ⏮ glyph is only shown when attached, since prefix+L only
  # works in the session you're attached to — showing it for other sessions
  # would be noise. The sort still ranks them in tier 3 internally.
  tmux list-windows -a -F '#{?session_attached,#{?window_active,0,#{?window_last_flag,2,4}},#{?window_active,1,#{?window_last_flag,3,5}}}|#{session_last_attached}|#{window_index}|[w] #{session_name}:#{window_index}#{?window_active, ✓,}#{?session_attached,#{?window_last_flag, ⏮,},}#{?window_activity_flag, ⚡,}#{?window_bell_flag, 🔔,}#{?window_silence_flag, 💤,}#{?window_zoomed_flag, 🔍,} #{?#{==:#{pane_title},#H},#{window_name},#{pane_title}}' 2>/dev/null \
    | sort -t'|' -k1,1n -k2,2rn -k3,3n | cut -d'|' -f4-

  sesh list -i --tmux --hide-attached 2>/dev/null | sed 's/^/[s] /'
  sesh list -i -c                      2>/dev/null | sed 's/^/[c] /'
  sesh list -i -z                      2>/dev/null | sed 's/^/[z] /'
}

selection=$(
  picker | fzf --ansi --no-sort \
    --prompt='sesh> ' \
    --header='[s]ession  [w]indow  [c]onfig  [z]oxide   (Esc to cancel)' \
    --header-first
) || exit 0

[[ -z "$selection" ]] && exit 0

kind="${selection:0:3}"
rest="${selection:4}"

case "$kind" in
  '[w]')
    target="${rest%% *}"
    exec tmux switch-client -t "$target"
    ;;
  *)
    exec sesh connect "$rest"
    ;;
esac
